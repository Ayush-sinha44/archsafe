# ArchSafe Configuration
# You can set API keys here or use: archsafe config set-key <KEY>

# Groq (default provider) — get key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# OpenAI (optional) — get key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here
